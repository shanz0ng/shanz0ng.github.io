---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Tag from "@components/Tag.astro";
import Datetime from "@components/Datetime";
import type { CollectionEntry } from "astro:content";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const { title, author, description, ogImage, pubDatetime, tags } = post.data;
const slug = post.slug;

const { Content } = await post.render();

const ogUrl = new URL(ogImage ? ogImage : `${title}.png`, Astro.url.origin)
  .href;
---

<Layout title={title} author={author} description={description} ogImage={ogUrl}>
  <Header />
  <div class="mx-auto flex w-full max-w-3xl justify-start px-2">
    <button
      class="focus-outline mt-8 mb-2 flex hover:opacity-75"
      onclick="history.back()"
    >
      <svg xmlns="http://www.w3.org/2000/svg"
        ><path
          d="M13.293 6.293 7.586 12l5.707 5.707 1.414-1.414L10.414 12l4.293-4.293z"
        ></path>
      </svg><span>Go back</span>
    </button>
  </div>
  <div class="post-wrapper">
    <main id="main-content">
      <h1 class="post-title">{title}</h1>
      <Datetime datetime={pubDatetime} size="lg" className="my-2" />
      <article id="article" role="article" class="prose mx-auto mt-8 max-w-3xl">
        <Content />
      </article>

      <ul class="tags-container">
        {tags.map(tag => <Tag name={tag} />)}
      </ul>

      <div class="mx-auto max-w-3xl mt-8 text-sm opacity-70">
        <span id="view-count">阅读 ...</span>
      </div>

      <div class="giscus-wrapper mx-auto max-w-3xl mt-12">
        <script src="https://giscus.app/client.js"
          data-repo="shanz0ng/shanz0ng.github.io"
          data-repo-id="R_kgDOS8UiLQ"
          data-category="General"
          data-category-id="DIC_kwDOS8UiLc4C_Q2i"
          data-mapping="pathname"
          data-strict="0"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="bottom"
          data-theme="light"
          data-lang="zh-CN"
          crossorigin="anonymous"
          async>
        </script>
      </div>
    </main>

    <aside id="toc-sidebar" class="toc-sidebar">
      <div class="toc-sticky">
        <div class="toc-header">
          <h3 class="toc-title">目录</h3>
          <button id="toc-toggle" class="toc-toggle" title="隐藏/显示目录">
            <svg id="toc-toggle-icon" width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
              <path fill-rule="evenodd" d="M7.78 12.53a.75.75 0 0 1-1.06 0L2.47 8.28a.75.75 0 0 1 1.06-1.06L8 11.69l4.47-4.47a.75.75 0 1 1 1.06 1.06l-5.25 5.25Z"/>
            </svg>
          </button>
        </div>
        <nav id="toc-nav">
          <ul id="toc-list" class="toc-list"></ul>
        </nav>
      </div>
    </aside>
    <button id="toc-float-toggle" class="toc-float-toggle hidden" title="显示目录">
      <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor">
        <path d="M2.5 3.5a.5.5 0 0 1 0-1h11a.5.5 0 0 1 0 1h-11Zm0 5a.5.5 0 0 1 0-1h11a.5.5 0 0 1 0 1h-11Zm0 5a.5.5 0 0 1 0-1h6a.5.5 0 0 1 0 1h-6Z"/>
      </svg>
    </button>
  </div>
  <Footer />
</Layout>

<style>
  .post-wrapper {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    gap: 2rem;
    padding: 0 1rem;
  }
  #main-content {
    width: 100%;
    min-width: 0;
    max-width: 48rem;
  }
  .post-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: rgb(var(--color-accent));
  }
  .tags-container {
    margin: 2rem 0;
  }

  /* TOC Sidebar */
  .toc-sidebar {
    display: none;
    width: 14rem;
    flex-shrink: 0;
    overflow: hidden;
    transition: width 0.3s ease, opacity 0.3s ease;
  }
  @media (min-width: 1024px) {
    .toc-sidebar {
      display: block;
    }
  }
  .toc-sidebar.collapsed {
    width: 0;
    opacity: 0;
    pointer-events: none;
  }
  .toc-sticky {
    position: sticky;
    top: 6rem;
    padding-top: 1.5rem;
  }
  .toc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    white-space: nowrap;
  }
  .toc-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: rgb(var(--color-accent));
    margin-bottom: 0;
  }
  .toc-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: rgb(var(--color-text-base));
    opacity: 0.5;
    padding: 2px;
    border-radius: 4px;
    transition: opacity 0.15s, transform 0.3s;
  }
  .toc-toggle:hover {
    opacity: 1;
    color: rgb(var(--color-accent));
  }
  .toc-float-toggle {
    position: fixed;
    right: 1rem;
    bottom: 5rem;
    z-index: 50;
    background: rgb(var(--color-accent));
    color: rgb(var(--color-bg));
    border: none;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    opacity: 0.85;
    transition: opacity 0.2s;
  }
  .toc-float-toggle:hover {
    opacity: 1;
  }
  .toc-float-toggle.hidden {
    display: none;
  }
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.875rem;
  }
  .toc-list li {
    margin-top: 0.375rem;
    margin-bottom: 0.375rem;
  }
  .toc-list a {
    color: rgb(var(--color-text-base));
    opacity: 0.7;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .toc-list a:hover {
    opacity: 1;
    color: rgb(var(--color-accent));
  }
  .toc-list a.active {
    opacity: 1;
    color: rgb(var(--color-accent));
    font-weight: 500;
  }
  .toc-list .toc-h3 {
    padding-left: 0.75rem;
  }
</style>

<script>
  // Build TOC from article headings
  function buildTOC() {
    const article = document.getElementById("article");
    if (!article) return;

    const headings = article.querySelectorAll("h2, h3");
    if (headings.length === 0) return;

    const tocList = document.getElementById("toc-list");
    if (!tocList) return;

    headings.forEach((heading) => {
      const li = document.createElement("li");
      li.className = heading.tagName === "H3" ? "toc-h3" : "";

      const a = document.createElement("a");
      a.href = `#${heading.id}`;
      a.textContent = heading.textContent;

      li.appendChild(a);
      tocList.appendChild(li);
    });
  }

  // Highlight current section on scroll
  function highlightTOC() {
    const article = document.getElementById("article");
    if (!article) return;

    const headings = article.querySelectorAll("h2, h3");
    const links = document.querySelectorAll("#toc-list a");

    let current = "";
    headings.forEach((heading) => {
      if (heading.getBoundingClientRect().top <= 120) {
        current = heading.id;
      }
    });

    links.forEach((link) => {
      link.classList.toggle("active", link.getAttribute("href") === `#${current}`);
    });
  }

  buildTOC();
  window.addEventListener("scroll", highlightTOC, { passive: true });

  // TOC toggle
  const sidebar = document.getElementById("toc-sidebar");
  const toggleBtn = document.getElementById("toc-toggle");
  const floatBtn = document.getElementById("toc-float-toggle");

  if (sidebar && toggleBtn && floatBtn) {
    const KEY = "toc-collapsed";

    function collapse() {
      sidebar.classList.add("collapsed");
      floatBtn.classList.remove("hidden");
      localStorage.setItem(KEY, "1");
    }
    function expand() {
      sidebar.classList.remove("collapsed");
      floatBtn.classList.add("hidden");
      localStorage.setItem(KEY, "0");
    }
    toggleBtn.addEventListener("click", () => {
      sidebar.classList.contains("collapsed") ? expand() : collapse();
    });
    floatBtn.addEventListener("click", expand);

    if (localStorage.getItem(KEY) === "1") collapse();
  }
</script>

<script type="module">
  import { createClient } from "https://esm.sh/@supabase/supabase-js@2";

  const supabase = createClient(
    "https://amcbgpyzytudmrlhbfvs.supabase.co",
    "sb_publishable_bLUM8CSIjC2Pc0C26bytyQ_jTpnfe1S"
  );

  const slug = "{slug}";

  const { data } = await supabase
    .rpc("increment_view", { page_slug: slug });

  const count = data ?? 1;
  const el = document.getElementById("view-count");
  if (el) el.textContent = `阅读 ${count}`;
</script>
