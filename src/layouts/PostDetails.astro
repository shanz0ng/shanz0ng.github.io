---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Tag from "@components/Tag.astro";
import Datetime from "@components/Datetime";
import type { CollectionEntry } from "astro:content";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const { title, author, description, ogImage, pubDatetime, tags } = post.data;
const slug = post.slug;

const { Content } = await post.render();

const ogUrl = new URL(ogImage ? ogImage : `${title}.png`, Astro.url.origin)
  .href;
---

<Layout title={title} author={author} description={description} ogImage={ogUrl}>
  <Header />
  <div class="mx-auto flex w-full max-w-3xl justify-start px-2">
    <button
      class="focus-outline mt-8 mb-2 flex hover:opacity-75"
      onclick="history.back()"
    >
      <svg xmlns="http://www.w3.org/2000/svg"
        ><path
          d="M13.293 6.293 7.586 12l5.707 5.707 1.414-1.414L10.414 12l4.293-4.293z"
        ></path>
      </svg><span>Go back</span>
    </button>
  </div>
  <div class="post-wrapper">
    <main id="main-content">
      <h1 class="post-title">{title}</h1>
      <Datetime datetime={pubDatetime} size="lg" className="my-2" />
      <article id="article" role="article" class="prose mx-auto mt-8 max-w-3xl">
        <Content />
      </article>

      <ul class="tags-container">
        {tags.map(tag => <Tag name={tag} />)}
      </ul>

      <div class="mx-auto max-w-3xl mt-8 text-sm opacity-70">
        <span id="view-count">阅读 ...</span>
      </div>

      <div class="giscus-wrapper mx-auto max-w-3xl mt-12">
        <script src="https://giscus.app/client.js"
          data-repo="shanz0ng/shanz0ng.github.io"
          data-repo-id="R_kgDOS8UiLQ"
          data-category="General"
          data-category-id="DIC_kwDOS8UiLc4C_Q2i"
          data-mapping="pathname"
          data-strict="0"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="bottom"
          data-theme="light"
          data-lang="zh-CN"
          crossorigin="anonymous"
          async>
        </script>
      </div>
    </main>

    <aside id="toc-sidebar" class="toc-sidebar">
      <div class="toc-header">
        <span class="toc-title">目录</span>
        <button id="toc-close" class="toc-close" title="隐藏目录">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
            <path fill-rule="evenodd" d="M11.854 4.146a.5.5 0 0 1 0 .708L8.707 8l3.147 3.146a.5.5 0 0 1-.708.708L8 8.707l-3.146 3.147a.5.5 0 0 1-.708-.708L7.293 8 4.146 4.854a.5.5 0 1 1 .708-.708L8 7.293l3.146-3.147a.5.5 0 0 1 .708 0z"/>
          </svg>
        </button>
      </div>
      <div class="toc-sticky">
        <nav id="toc-nav">
          <ul id="toc-list" class="toc-list"></ul>
        </nav>
      </div>
    </aside>
    <button id="toc-tab" class="toc-tab hidden" title="显示目录">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
        <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z"/>
      </svg>
      <span class="toc-tab-label">目录</span>
    </button>
  </div>
  <Footer />
</Layout>

<style>
  .post-wrapper {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    gap: 2rem;
    padding: 0 1rem;
  }
  #main-content {
    width: 100%;
    min-width: 0;
    max-width: 48rem;
  }
  .post-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: rgb(var(--color-accent));
  }
  .tags-container {
    margin: 2rem 0;
  }

  /* TOC Sidebar — fixed right, slide in/out */
  .toc-sidebar {
    position: fixed;
    top: 0;
    right: 0;
    width: 16rem;
    height: 100vh;
    z-index: 60;
    background: rgb(var(--color-bg));
    border-left: 1px solid rgb(var(--color-text-base) / 0.15);
    transform: translateX(0);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
  }
  .toc-sidebar.collapsed {
    transform: translateX(100%);
  }
  .toc-sticky {
    flex: 1;
    overflow-y: auto;
    padding-top: 0.5rem;
  }
  .toc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgb(var(--color-text-base) / 0.1);
  }
  .toc-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: rgb(var(--color-accent));
  }
  .toc-close {
    background: none;
    border: none;
    cursor: pointer;
    color: rgb(var(--color-text-base));
    opacity: 0.4;
    padding: 4px;
    border-radius: 4px;
    transition: opacity 0.15s;
  }
  .toc-close:hover {
    opacity: 1;
    color: rgb(var(--color-accent));
  }

  /* Toggle tab — always visible at right edge */
  .toc-tab {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 59;
    background: rgb(var(--color-bg));
    border: 1px solid rgb(var(--color-text-base) / 0.15);
    border-right: none;
    border-radius: 6px 0 0 6px;
    padding: 0.75rem 0.5rem;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    color: rgb(var(--color-text-base));
    opacity: 0.6;
    transition: opacity 0.15s, transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: -1px 0 4px rgba(0,0,0,0.08);
  }
  .toc-tab:hover {
    opacity: 1;
    color: rgb(var(--color-accent));
  }
  .toc-tab.hidden {
    opacity: 0;
    pointer-events: none;
  }
  .toc-tab-label {
    writing-mode: vertical-lr;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
  }
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.875rem;
  }
  .toc-list li {
    margin-top: 0.375rem;
    margin-bottom: 0.375rem;
  }
  .toc-list a {
    color: rgb(var(--color-text-base));
    opacity: 0.7;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .toc-list a:hover {
    opacity: 1;
    color: rgb(var(--color-accent));
  }
  .toc-list a {
    position: relative;
    padding-left: 0.75rem;
    border-left: 2px solid transparent;
    transition: border-color 0.2s, color 0.2s, opacity 0.2s;
    display: block;
  }
  .toc-list a.active {
    opacity: 1;
    color: rgb(var(--color-accent));
    font-weight: 500;
    border-left-color: rgb(var(--color-accent));
  }
  .toc-list .toc-h3 {
    padding-left: 0.75rem;
  }
</style>

<script>
  // Build TOC from article headings
  function buildTOC() {
    const article = document.getElementById("article");
    if (!article) return;

    const headings = article.querySelectorAll("h2, h3");
    if (headings.length === 0) return;

    const tocList = document.getElementById("toc-list");
    if (!tocList) return;

    headings.forEach((heading) => {
      const li = document.createElement("li");
      li.className = heading.tagName === "H3" ? "toc-h3" : "";

      const a = document.createElement("a");
      a.href = `#${heading.id}`;
      a.textContent = heading.textContent;

      li.appendChild(a);
      tocList.appendChild(li);
    });
  }

  // Highlight current section on scroll
  function highlightTOC() {
    const article = document.getElementById("article");
    if (!article) return;

    const headings = article.querySelectorAll("h2, h3");
    const links = document.querySelectorAll("#toc-list a");

    let current = "";
    headings.forEach((heading) => {
      if (heading.getBoundingClientRect().top <= 120) {
        current = heading.id;
      }
    });

    links.forEach((link) => {
      link.classList.toggle("active", link.getAttribute("href") === `#${current}`);
    });
  }

  buildTOC();
  window.addEventListener("scroll", highlightTOC, { passive: true });

  // TOC toggle — slide from right
  const sidebar = document.getElementById("toc-sidebar");
  const closeBtn = document.getElementById("toc-close");
  const tabBtn = document.getElementById("toc-tab");

  if (sidebar && closeBtn && tabBtn) {
    const KEY = "toc-collapsed";

    function show() {
      sidebar.classList.remove("collapsed");
      tabBtn.classList.add("hidden");
      localStorage.setItem(KEY, "0");
    }
    function hide() {
      sidebar.classList.add("collapsed");
      tabBtn.classList.remove("hidden");
      localStorage.setItem(KEY, "1");
    }
    closeBtn.addEventListener("click", hide);
    tabBtn.addEventListener("click", show);

    if (localStorage.getItem(KEY) === "1") {
      sidebar.classList.add("collapsed");
      tabBtn.classList.remove("hidden");
    }
  }
</script>

<script type="module">
  import { createClient } from "https://esm.sh/@supabase/supabase-js@2";

  const supabase = createClient(
    "https://amcbgpyzytudmrlhbfvs.supabase.co",
    "sb_publishable_bLUM8CSIjC2Pc0C26bytyQ_jTpnfe1S"
  );

  const slug = "{slug}";

  const { data } = await supabase
    .rpc("increment_view", { page_slug: slug });

  const count = data ?? 1;
  const el = document.getElementById("view-count");
  if (el) el.textContent = `阅读 ${count}`;
</script>
