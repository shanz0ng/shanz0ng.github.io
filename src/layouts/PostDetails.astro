---
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Tag from "@components/Tag.astro";
import Datetime from "@components/Datetime";
import type { CollectionEntry } from "astro:content";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;

const { title, author, description, ogImage, pubDatetime, tags } = post.data;
const slug = post.slug;

const { Content } = await post.render();

const ogUrl = new URL(ogImage ? ogImage : `${title}.png`, Astro.url.origin)
  .href;
---

<Layout title={title} author={author} description={description} ogImage={ogUrl}>
  <Header />
  <div class="mx-auto flex w-full max-w-3xl justify-start px-2">
    <button
      class="focus-outline mt-8 mb-2 flex hover:opacity-75"
      onclick="history.back()"
    >
      <svg xmlns="http://www.w3.org/2000/svg"
        ><path
          d="M13.293 6.293 7.586 12l5.707 5.707 1.414-1.414L10.414 12l4.293-4.293z"
        ></path>
      </svg><span>Go back</span>
    </button>
  </div>
  <div class="post-wrapper">
    <main id="main-content">
      <h1 class="post-title">{title}</h1>
      <Datetime datetime={pubDatetime} size="lg" className="my-2" />
      <article id="article" role="article" class="prose mx-auto mt-8 max-w-3xl">
        <Content />
      </article>

      <ul class="tags-container">
        {tags.map(tag => <Tag name={tag} />)}
      </ul>

      <div class="mx-auto mt-8 max-w-3xl text-sm opacity-70">
        <span id="view-count" class="view-count-loading">阅读统计中...</span>
        <span id="busuanzi_container_page_pv" style="display:none">
          阅读 <span id="busuanzi_value_page_pv"></span>
        </span>
      </div>

      <div class="giscus-wrapper mx-auto max-w-3xl mt-12">
        <script src="https://giscus.app/client.js"
          data-repo="shanz0ng/shanz0ng.github.io"
          data-repo-id="R_kgDOTQguag"
          data-category="General"
          data-category-id="DIC_kwDOTQguas4DBJc4"
          data-mapping="pathname"
          data-strict="0"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="bottom"
          data-theme="light"
          data-lang="zh-CN"
          crossorigin="anonymous"
          async>
        </script>
      </div>
    </main>

    <aside id="toc-sidebar" class="toc-sidebar">
      <div class="toc-header">
        <span class="toc-title">目录</span>
        <button id="toc-close" class="toc-close" title="隐藏目录">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
            <path fill-rule="evenodd" d="M11.854 4.146a.5.5 0 0 1 0 .708L8.707 8l3.147 3.146a.5.5 0 0 1-.708.708L8 8.707l-3.146 3.147a.5.5 0 0 1-.708-.708L7.293 8 4.146 4.854a.5.5 0 1 1 .708-.708L8 7.293l3.146-3.147a.5.5 0 0 1 .708 0z"/>
          </svg>
        </button>
      </div>
      <div class="toc-progress">
        <div class="toc-progress-meta">
          <span class="toc-progress-label">已读</span>
          <span id="toc-progress-value" class="toc-progress-value">0%</span>
        </div>
        <div class="toc-progress-track" aria-hidden="true">
          <div id="toc-progress-bar" class="toc-progress-bar"></div>
        </div>
      </div>
      <div class="toc-sticky">
        <nav id="toc-nav">
          <ol id="toc-list" class="toc-list"></ol>
        </nav>
      </div>
    </aside>
    <button id="toc-tab" class="toc-tab hidden" title="显示目录">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
        <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5z"/>
      </svg>
      <span class="toc-tab-label">目录</span>
    </button>
  </div>
  <Footer />
</Layout>

<style>
  .post-wrapper {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    gap: 2rem;
    padding: 0 1rem;
  }
  #main-content {
    width: 100%;
    min-width: 0;
    max-width: 48rem;
  }
  .post-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: rgb(var(--color-accent));
  }
  .tags-container {
    margin: 2rem 0;
  }

  /* TOC sidebar: fixed right, slide in/out */
  .toc-sidebar {
    position: fixed;
    top: 0;
    right: 0;
    width: clamp(18rem, 24vw, 20rem);
    max-width: calc(100vw - 1.5rem);
    height: 100vh;
    box-sizing: border-box;
    z-index: 60;
    background: rgb(var(--color-bg));
    border-left: 1px solid rgb(var(--color-text-base) / 0.15);
    transform: translateX(0);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
  }
  .toc-sidebar.collapsed {
    transform: translateX(100%);
  }
  .toc-sticky {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding-top: 0.5rem;
  }
  .toc-progress {
    margin-bottom: 1rem;
    padding: 0.875rem 0.9rem;
    border-radius: 0.85rem;
    background: linear-gradient(
      180deg,
      rgb(var(--color-fill) / 0.9),
      rgb(var(--color-fill) / 0.55)
    );
    border: 1px solid rgb(var(--color-text-base) / 0.08);
  }
  .toc-progress-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
  }
  .toc-progress-label {
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: rgb(var(--color-text-base) / 0.68);
  }
  .toc-progress-value {
    font-size: 1.1rem;
    font-weight: 700;
    color: rgb(var(--color-accent));
  }
  .toc-progress-track {
    height: 0.45rem;
    border-radius: 999px;
    background: rgb(var(--color-text-base) / 0.08);
    overflow: hidden;
  }
  .toc-progress-bar {
    width: 0%;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(
      90deg,
      rgb(var(--color-accent) / 0.65),
      rgb(var(--color-accent))
    );
    transition: width 0.18s ease;
  }
  .toc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgb(var(--color-text-base) / 0.1);
  }
  .toc-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: rgb(var(--color-accent));
  }
  .toc-close {
    background: none;
    border: none;
    cursor: pointer;
    color: rgb(var(--color-text-base));
    opacity: 0.4;
    padding: 4px;
    border-radius: 4px;
    transition: opacity 0.15s;
  }
  .toc-close:hover {
    opacity: 1;
    color: rgb(var(--color-accent));
  }

  /* Toggle tab: always visible at right edge */
  .toc-tab {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 59;
    background: rgb(var(--color-bg));
    border: 1px solid rgb(var(--color-text-base) / 0.15);
    border-right: none;
    border-radius: 6px 0 0 6px;
    padding: 0.75rem 0.5rem;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    color: rgb(var(--color-text-base));
    opacity: 0.6;
    transition: opacity 0.15s, transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: -1px 0 4px rgba(0,0,0,0.08);
  }
  .toc-tab:hover {
    opacity: 1;
    color: rgb(var(--color-accent));
  }
  .toc-tab.hidden {
    opacity: 0;
    pointer-events: none;
  }
  .toc-tab-label {
    writing-mode: vertical-lr;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
  }
  .toc-list {
    list-style: decimal;
    list-style-position: outside;
    padding-left: 1.15rem;
    margin: 0;
    font-size: 0.875rem;
    overflow-wrap: anywhere;
  }
  .toc-list :global(li) {
    margin: 0.2rem 0;
    color: rgb(var(--color-text-base) / 0.5);
  }
  .toc-list :global(ol) {
    margin: 0.25rem 0 0.3rem;
    padding-left: 1rem;
  }
  .toc-list :global(a) {
    color: rgb(var(--color-text-base));
    opacity: 0.7;
    text-decoration: none;
    display: block;
    position: relative;
    min-width: 0;
    padding: 0.34rem 0.55rem 0.34rem 0.85rem;
    border-left: 3px solid transparent;
    border-radius: 0 0.5rem 0.5rem 0;
    line-height: 1.45;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
    transition:
      opacity 0.15s,
      color 0.15s,
      border-color 0.2s,
      background-color 0.2s;
  }
  .toc-list :global(a:hover) {
    opacity: 1;
    color: rgb(var(--color-accent));
  }
  .toc-list :global(li.active-parent > a:not(.active)) {
    opacity: 0.95;
    color: rgba(var(--color-accent), 0.88);
    background: rgba(var(--color-accent), 0.06);
  }
  .toc-list :global(a.active) {
    opacity: 1 !important;
    color: rgb(var(--color-accent)) !important;
    font-weight: 700;
    border-left-color: rgb(var(--color-accent));
    background: linear-gradient(
      90deg,
      rgba(var(--color-accent), 0.16),
      rgba(var(--color-accent), 0.06)
    );
  }
  .toc-list :global(a.active::before) {
    content: "";
    position: absolute;
    left: -0.44rem;
    top: 50%;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: rgb(var(--color-accent));
    box-shadow: 0 0 0 3px rgba(var(--color-accent), 0.16);
    transform: translateY(-50%);
  }
  .toc-list :global(li.active-parent) {
    color: rgb(var(--color-accent) / 0.9);
  }
  .toc-list :global(.toc-h3) {
    list-style: decimal;
  }
  .view-count-loading {
    display: inline-block;
  }

  @media (max-width: 1279px) {
    .toc-sidebar {
      width: 17rem;
    }
  }

  @media (max-width: 1023px) {
    .post-wrapper {
      display: block;
      max-width: 48rem;
    }
    .toc-sidebar {
      width: 16rem;
      padding: 1rem;
    }
  }

  @media (max-width: 767px) {
    .toc-sidebar,
    .toc-tab {
      display: none;
    }
  }
</style>

<script>
  function buildTOC() {
    const article = document.getElementById("article");
    if (!article) return;

    const headings = Array.from(article.querySelectorAll("h2, h3")).filter(
      heading => heading.id
    );
    if (headings.length === 0) return;

    const tocList = document.getElementById("toc-list");
    if (!tocList) return;

    tocList.innerHTML = "";

    let currentH2Item = null;
    let currentH2Children = null;

    headings.forEach((heading) => {
      const li = document.createElement("li");
      li.className = heading.tagName === "H3" ? "toc-h3" : "";

      const a = document.createElement("a");
      a.href = `#${heading.id}`;
      a.textContent = heading.textContent;

      li.appendChild(a);

      if (heading.tagName === "H2") {
        currentH2Item = li;
        currentH2Children = document.createElement("ol");
        currentH2Item.appendChild(currentH2Children);
        tocList.appendChild(currentH2Item);
        return;
      }

      if (currentH2Children) {
        currentH2Children.appendChild(li);
      } else {
        tocList.appendChild(li);
      }
    });

    setupTOCHighlight(headings);
    updateTOCProgress();
  }

  function setupTOCHighlight(headings) {
    const links = Array.from(document.querySelectorAll("#toc-list a"));
    if (!links.length) return;

    let activeId = "";

    const setActive = id => {
      if (!id || id === activeId) return;
      activeId = id;

      document.querySelectorAll("#toc-list li.active-parent").forEach(item => {
        item.classList.remove("active-parent");
      });

      links.forEach(link => {
        const isActive = link.getAttribute("href") === `#${id}`;
        link.classList.toggle("active", isActive);
        if (isActive) {
          link.setAttribute("aria-current", "true");
        } else {
          link.removeAttribute("aria-current");
        }

        if (isActive) {
          let node = link.closest("li");
          while (node) {
            node.classList.add("active-parent");
            node = node.parentElement?.closest("li");
          }
          link.scrollIntoView({ block: "nearest", inline: "nearest" });
        }
      });
    };

    const updateActiveHeading = () => {
      const anchor = Math.max(120, window.innerHeight * 0.28);
      let current = headings[0];

      for (const heading of headings) {
        if (heading.getBoundingClientRect().top <= anchor) {
          current = heading;
        } else {
          break;
        }
      }

      setActive(current?.id ?? headings[0]?.id ?? "");
    };

    const requestUpdate = () => {
      updateActiveHeading();
    };

    updateActiveHeading();
    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);
    if (typeof window.setInterval === "function") {
      window.setInterval(requestUpdate, 300);
    }
  }

  function updateTOCProgress() {
    const article = document.getElementById("article");
    const value = document.getElementById("toc-progress-value");
    const bar = document.getElementById("toc-progress-bar");
    if (!article || !value || !bar) return;

    const articleTop = window.scrollY + article.getBoundingClientRect().top;
    const articleHeight = article.offsetHeight;
    const viewportAnchor = window.scrollY + window.innerHeight * 0.28;
    const rawProgress = ((viewportAnchor - articleTop) / articleHeight) * 100;
    const progress = Math.max(0, Math.min(100, Math.round(rawProgress)));

    value.textContent = `${progress}%`;
    bar.style.width = `${progress}%`;
  }

  buildTOC();
  window.addEventListener("scroll", updateTOCProgress, { passive: true });
  window.addEventListener("resize", updateTOCProgress);
  if (typeof window.setInterval === "function") {
    window.setInterval(updateTOCProgress, 500);
  }

  const sidebar = document.getElementById("toc-sidebar");
  const closeBtn = document.getElementById("toc-close");
  const tabBtn = document.getElementById("toc-tab");

  if (sidebar && closeBtn && tabBtn) {
    const KEY = "toc-collapsed";

    function show() {
      sidebar.classList.remove("collapsed");
      tabBtn.classList.add("hidden");
      localStorage.setItem(KEY, "0");
    }
    function hide() {
      sidebar.classList.add("collapsed");
      tabBtn.classList.remove("hidden");
      localStorage.setItem(KEY, "1");
    }
    closeBtn.addEventListener("click", hide);
    tabBtn.addEventListener("click", show);

    if (localStorage.getItem(KEY) === "1") {
      sidebar.classList.add("collapsed");
      tabBtn.classList.remove("hidden");
    }
  }
</script>

<script is:inline src="//cdn.jsdelivr.net/npm/busuanzi@2.3.0/bsz.pure.mini.js" async></script>

<script>
  const el = document.getElementById("view-count");
  const counter = document.getElementById("busuanzi_container_page_pv");

  function syncViewCount() {
    if (!el || !counter) return;

    const value = document.getElementById("busuanzi_value_page_pv")?.textContent?.trim();
    if (value) {
      el.style.display = "none";
      counter.style.display = "inline";
      return true;
    }

    return false;
  }

  let attempts = 0;
  const timer = window.setInterval(() => {
    attempts += 1;

    if (syncViewCount()) {
      window.clearInterval(timer);
      return;
    }

    if (attempts >= 20) {
      if (el) {
        el.textContent = "阅读统计暂不可用";
      }
      window.clearInterval(timer);
    }
  }, 500);
</script>


